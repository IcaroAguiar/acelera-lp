# Públicas (build-time) — prefixo PUBLIC_ expõe ao cliente Astro

# URL canônica da LP (Open Graph, canonical)
PUBLIC_SITE_URL=https://aceleraconexoes.com.br

# WhatsApp flutuante e rodapé (somente dígitos, ex: 5511999999999)
PUBLIC_WHATSAPP_PHONE=

# Webhook JSON do formulário (Make, Zapier, n8n, CRM, etc.)
PUBLIC_FORM_WEBHOOK_URL=

# Analytics (opcional até IDs oficiais)
PUBLIC_GA4_ID=
PUBLIC_META_PIXEL_ID=
