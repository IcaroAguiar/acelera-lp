---
const daySteps = [
  {
    step: "01",
    icon: "login",
    title: "Chegada",
    body: "Recepção exclusiva no pit lane, credenciamento, briefing de pista e momento inicial de apresentação do grupo.",
    featured: false,
  },
  {
    step: "02",
    icon: "speed",
    title: "Pista",
    body: "Pilotagem em carros esportivos com instrução de piloto profissional. Você dirige, não assiste.",
    featured: true,
  },
  {
    step: "03",
    icon: "sports_esports",
    title: "Simulador",
    body: "Competição em simulador profissional com ranking ao vivo entre os participantes.",
    featured: false,
  },
  {
    step: "04",
    icon: "groups",
    title: "Dinâmicas",
    body: "Atividades estratégicas desenhadas para gerar conexões reais de negócio entre empresários.",
    featured: false,
  },
  {
    step: "05",
    icon: "restaurant",
    title: "Almoço premium",
    body: "Mesa compartilhada com todo o grupo. É aqui que o networking acontece de verdade.",
    featured: false,
  },
  {
    step: "06",
    icon: "emoji_events",
    title: "Pódio",
    body: "Cerimônia de encerramento, ranking final e reconhecimento dos destaques do dia.",
    featured: false,
  },
];
---
<!-- Etapas da Experiência -->
<section class="py-section-gap-mobile md:py-section-gap-desktop bg-track-asphalt" id="etapas">
  <div class="px-gutter max-w-container-max mx-auto">
    <div class="text-center mb-16 reveal-hidden">
      <p class="font-label-caps text-label-caps text-primary tracking-widest uppercase mb-2">Seu dia completo</p>
      <h2 class="font-section-title text-section-title text-performance-white uppercase">
        O que acontece no seu dia <span class="text-primary block">em Interlagos</span>
      </h2>
      <p class="font-body-lg text-body-lg text-metallic-grey mt-6 max-w-[65ch] mx-auto">
        Da chegada ao pódio: um dia inteiro de pilotagem, competição, dinâmicas e conexões no autódromo mais icônico do Brasil.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {daySteps.map((item, index) => (
        <div
          class:list={[
            "timeline-card bg-pit-lane-navy/80 backdrop-blur-sm border-l-2 border-primary/30 p-8 flex flex-col justify-between group hover:border-primary hover:bg-surface-container-high transition-all duration-500 reveal-hidden cursor-default hover:-translate-y-2 hover:shadow-[0_10px_30px_rgba(0,0,0,0.5),0_0_20px_rgba(200,160,40,0.15)]",
            item.featured && "relative overflow-hidden",
          ]}
          style={`transition-delay: ${index * 75}ms`}
        >
          {item.featured && (
            <div
              class="absolute inset-0 opacity-10 group-hover:opacity-20 transition-opacity duration-500 z-0 mix-blend-screen"
              style="background-image: image-set(url('/images/hero-interlagos.webp') type('image/webp'), url('/images/hero-interlagos.jpg') type('image/jpeg')); background-size: cover; background-position: center;"
            />
          )}
          <div class="flex justify-between items-start mb-6 relative z-10">
            <span class="font-hero-headline-mobile text-[48px] text-primary/20 group-hover:text-primary transition-colors leading-none drop-shadow-[0_0_8px_rgba(237,193,72,0)] group-hover:drop-shadow-[0_0_8px_rgba(237,193,72,0.5)]">
              {item.step}
            </span>
            <span class="material-symbols-outlined text-primary group-hover:scale-110 transition-transform">{item.icon}</span>
          </div>
          <div class="timeline-card-content relative z-10">
            <h3 class="font-hero-headline-mobile text-[28px] text-performance-white uppercase mb-2 tracking-wider group-hover:text-primary transition-colors">
              {item.title}
            </h3>
            <p class="font-body-md text-microcopy text-metallic-grey leading-relaxed">{item.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
