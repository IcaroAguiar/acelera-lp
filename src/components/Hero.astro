---
import OptimizedPicture from "./OptimizedPicture.astro";

const heroVideos = {
  desktopWebm: "/videos/hero-acelera-720.webm",
  desktopMp4: "/videos/hero-acelera-1080.mp4",
  mobileWebm: "/videos/hero-acelera-720.webm",
  mobileMp4: "/videos/hero-acelera-720.mp4",
  poster: "/images/interlagos-aerial.webp",
} as const;
---
<!-- Hero Section -->
<header class="relative min-h-[90vh] md:min-h-screen flex items-center w-full pt-20 overflow-hidden">
  <div class="absolute inset-0 w-full h-full overflow-hidden" id="hero-parallax-media">
    <OptimizedPicture
      base="/images/interlagos-aerial"
      webpSrcSet="/images/interlagos-aerial-1280.webp 1280w, /images/interlagos-aerial.webp 1920w"
      sizes="100vw"
      class="w-full h-full object-cover object-center filter brightness-[0.82] contrast-[1.1] saturate-[1.05] transition-opacity duration-700"
      id="hero-poster-img"
      alt="Vista aérea do Autódromo de Interlagos"
      loading="eager"
      fetchpriority="high"
      width={1920}
      height={1280}
    />
    <video
      id="hero-parallax-video"
      class="absolute inset-0 w-full h-full object-cover object-center filter brightness-[0.82] contrast-[1.1] saturate-[1.05] opacity-0 transition-opacity duration-700 pointer-events-none"
      muted
      loop
      playsinline
      disablepictureinpicture
      disableremoteplayback
      preload="none"
      poster={heroVideos.poster}
      aria-hidden="true"
      tabindex="-1"
    >
    </video>
    <div class="absolute inset-0 bg-gradient-to-r from-track-asphalt/85 via-track-asphalt/55 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-track-asphalt via-track-asphalt/35 to-transparent"></div>
    <div class="absolute inset-0 shimmer-overlay"></div>
  </div>
  <div class="relative z-10 px-gutter w-full max-w-container-max mx-auto flex flex-col items-start justify-center">
    <div class="max-w-3xl">
      <div class="inline-flex items-center gap-2 mb-6 border border-primary/30 bg-primary/10 px-3 py-1 rounded-sm animate-fade-up">
        <span class="material-symbols-outlined text-primary text-[16px]">verified</span>
        <span class="font-label-caps text-microcopy text-primary tracking-widest uppercase">Vagas limitadas · Processo de seleção</span>
      </div>
      <h1 class="font-hero-headline-mobile md:font-hero-headline text-hero-headline-mobile md:text-hero-headline text-performance-white mb-6 uppercase animate-fade-up delay-100">
        Você vai pilotar<br /><span class="text-primary">em Interlagos.</span>
      </h1>
      <p class="font-body-lg text-body-lg text-metallic-grey mb-10 max-w-2xl animate-fade-up delay-200">
        Um dia inteiro na pista mais icônica do Brasil. Ao lado de empresários que constroem negócios de alto nível.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 animate-fade-up delay-300">
        <div class="inline-block p-4 -m-4 cursor-pointer" id="magnetic-wrapper">
          <a
            class="magnetic-btn justify-center items-center bg-podium-gold text-on-primary font-label-caps text-label-caps px-8 py-4 uppercase tracking-widest transition-all duration-300 animate-breathe btn-glow"
            href="#aplicacao"
            id="magnetic-element"
            style="transform: translate(0px, 0px);"
          >
            QUERO PARTICIPAR
          </a>
        </div>
        <a
          class="inline-flex justify-center items-center border border-metallic-grey/40 text-performance-white font-label-caps text-label-caps px-8 py-4 uppercase tracking-widest hover:border-performance-white hover:bg-white/5 transition-colors duration-300 mt-0 sm:ml-4"
          href="#experiencia"
        >
          CONHECER A EXPERIÊNCIA
        </a>
      </div>
    </div>
  </div>
</header>

<script define:vars={{ heroVideos }}>
  const posterImg = document.getElementById("hero-poster-img");
  const video = document.getElementById("hero-parallax-video");

  const canAutoplayVideo = () => {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      return false;
    }

    const connection = navigator.connection;
    if (connection?.saveData) {
      return false;
    }

    const slowTypes = ["slow-2g", "2g"];
    if (connection?.effectiveType && slowTypes.includes(connection.effectiveType)) {
      return false;
    }

    return true;
  };

  const pickVideoSrc = () => {
    const isDesktop = window.matchMedia("(min-width: 1024px)").matches;
    const supportsWebm = video instanceof HTMLVideoElement && video.canPlayType('video/webm; codecs="vp9"') !== "";

    if (isDesktop) {
      return supportsWebm ? heroVideos.desktopWebm : heroVideos.desktopMp4;
    }

    return supportsWebm ? heroVideos.mobileWebm : heroVideos.mobileMp4;
  };

  const revealVideo = () => {
    if (!(video instanceof HTMLVideoElement)) {
      return;
    }

    video.classList.remove("opacity-0");
    if (posterImg instanceof HTMLElement) {
      posterImg.classList.add("opacity-0");
    }
  };

  const loadHeroVideo = () => {
    if (!(video instanceof HTMLVideoElement) || !canAutoplayVideo()) {
      return;
    }

    const src = pickVideoSrc();
    if (video.dataset.loadedSrc === src) {
      return;
    }

    video.dataset.loadedSrc = src;
    video.src = src;
    video.load();

    const playPromise = video.play();
    if (playPromise) {
      playPromise
        .then(() => {
          revealVideo();
        })
        .catch(() => {
          video.removeAttribute("src");
          video.load();
          delete video.dataset.loadedSrc;
        });
    }
  };

  const scheduleHeroVideo = () => {
    const run = () => loadHeroVideo();
    if ("requestIdleCallback" in window) {
      requestIdleCallback(run, { timeout: 2500 });
    } else {
      window.setTimeout(run, 1200);
    }
  };

  if (document.readyState === "complete") {
    scheduleHeroVideo();
  } else {
    window.addEventListener("load", scheduleHeroVideo, { once: true });
  }
</script>
