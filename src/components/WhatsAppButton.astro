---
import { site } from "../config/site";

const whatsappHref = site.whatsappPhone
  ? `https://wa.me/${site.whatsappPhone.replace(/\D/g, "")}`
  : "#aplicacao";
---
<!-- Floating WhatsApp -->
<a
  aria-label="Contato via WhatsApp"
  class="fixed bottom-6 right-6 w-14 h-14 bg-pit-lane-navy border border-primary text-primary rounded-full flex items-center justify-center shadow-lg hover:bg-primary hover:text-track-asphalt hover:scale-110 transition-all duration-300 z-50 group"
  href={whatsappHref}
  rel="noopener noreferrer"
  target={site.whatsappPhone ? "_blank" : undefined}
>
  <span class="material-symbols-outlined text-[28px]">chat</span>
</a>
